# Heap environment (app) ID used by default on every call.
# Find it in Heap under Account > Manage > Projects.
HEAP_APP_ID=

# API key, required ONLY for the user-deletion tools.
# Admins generate this in Heap under Account > Manage > Privacy & Security.
# For deletion, HEAP_APP_ID must be your Main Production environment ID.
HEAP_API_KEY=

# Datacenter: "us" (default) or "eu".
HEAP_DATA_CENTER=us

# Optional: override the Heap host (e.g. a proxy/gateway in front of Heap).
# When set, it applies to both ingestion and deletion endpoints.
# HEAP_BASE_URL=https://my-heap-proxy.example.com

# Transport: "stdio" (default) or "http".
TRANSPORT=stdio

# Port for the http transport.
PORT=3000
