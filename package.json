{
  "name": "heap-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Heap Analytics (heap.io) server-side API integration",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "heap-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "npm run build && node --test",
    "test:only": "node --test",
    "check:heap-api": "node scripts/check-heap-api.mjs",
    "prepublishOnly": "npm run build && npm run test:only"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "heap",
    "heap-analytics",
    "heap.io",
    "analytics",
    "llm",
    "ai",
    "agent",
    "tools"
  ],
  "author": "<YOUR NAME OR ORGANIZATION>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rivit-studio/heap-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/rivit-studio/heap-mcp-server/issues"
  },
  "homepage": "https://github.com/rivit-studio/heap-mcp-server#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "axios": "^1.7.9",
    "express": "^4.21.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
